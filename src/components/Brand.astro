---
interface Props {
  variant?: "mint" | "ink" | "canvas";
  class?: string;
  size?: number;
}
const { variant = "mint", class: className = "", size = 32 } = Astro.props;

const colorMap: Record<string, string> = {
  mint: "var(--color-mint-deep)",
  ink: "var(--color-ink)",
  canvas: "var(--color-canvas)",
};
const bgColor = colorMap[variant];
---

<span
  class={`brand-mark inline-block shrink-0 ${className}`}
  role="img"
  aria-label="Schut Marketing"
  style={`width:${size}px;height:${size}px;background-color:${bgColor};`}
></span>

<style>
  .brand-mark {
    -webkit-mask: url("/brand/schut-logo-light.png") center / contain no-repeat;
            mask: url("/brand/schut-logo-light.png") center / contain no-repeat;
  }
</style>
