---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = "", size = 32 } = Astro.props;
---

<img
  src="/brand/schut-logo-mint.png"
  alt="Schut Marketing"
  width={size}
  height={size}
  class={`inline-block shrink-0 ${className}`}
  style={`width:${size}px;height:${size}px;`}
  fetchpriority="high"
  decoding="async"
/>
