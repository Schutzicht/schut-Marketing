---
interface Props {
  name:
    | "arrow"
    | "arrow-up-right"
    | "menu"
    | "close"
    | "phone"
    | "mail"
    | "pin"
    | "linkedin"
    | "instagram"
    | "globe"
    | "target"
    | "search"
    | "compass"
    | "spark"
    | "check"
    | "quote";
  class?: string;
  size?: number;
}
const { name, class: className = "", size = 22 } = Astro.props;
---

{name === "arrow" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
  </svg>
)}
{name === "arrow-up-right" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M7 17 17 7"/><path d="M8 7h9v9"/>
  </svg>
)}
{name === "menu" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class={className} aria-hidden="true">
    <path d="M4 8h16"/><path d="M4 16h16"/>
  </svg>
)}
{name === "close" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class={className} aria-hidden="true">
    <path d="M6 6 18 18"/><path d="M18 6 6 18"/>
  </svg>
)}
{name === "phone" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M22 16.92v2.5a2 2 0 0 1-2.18 2 19.5 19.5 0 0 1-8.5-3 19.2 19.2 0 0 1-6-6 19.5 19.5 0 0 1-3-8.55A2 2 0 0 1 4.32 2h2.5a2 2 0 0 1 2 1.7c.13.9.34 1.78.64 2.62a2 2 0 0 1-.45 2.12L7.9 9.55a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.12-.45c.84.3 1.72.51 2.62.64a2 2 0 0 1 1.7 2Z"/>
  </svg>
)}
{name === "mail" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>
  </svg>
)}
{name === "pin" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M20 10c0 7-8 12-8 12s-8-5-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
  </svg>
)}
{name === "linkedin" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="3"/>
    <path d="M8 11v6"/><circle cx="8" cy="8" r="0.6" fill="currentColor"/>
    <path d="M12 17v-3.5a2.5 2.5 0 0 1 5 0V17"/>
    <path d="M12 11v6"/>
  </svg>
)}
{name === "instagram" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
  </svg>
)}
{name === "globe" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="9"/>
    <path d="M3 12h18"/>
    <path d="M12 3a14 14 0 0 1 0 18"/>
    <path d="M12 3a14 14 0 0 0 0 18"/>
  </svg>
)}
{name === "target" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.4" fill="currentColor"/>
  </svg>
)}
{name === "search" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="11" cy="11" r="7"/><path d="m20 20-4.5-4.5"/>
  </svg>
)}
{name === "compass" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="9"/>
    <path d="m15.5 8.5-2 5-5 2 2-5 5-2Z"/>
  </svg>
)}
{name === "spark" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M12 3v4"/><path d="M12 17v4"/><path d="M3 12h4"/><path d="M17 12h4"/>
    <path d="m5.6 5.6 2.8 2.8"/><path d="m15.6 15.6 2.8 2.8"/>
    <path d="m18.4 5.6-2.8 2.8"/><path d="m8.4 15.6-2.8 2.8"/>
  </svg>
)}
{name === "check" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="m5 12 5 5 9-11"/>
  </svg>
)}
{name === "quote" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M7 7h4v4H8c0 2 1 3 3 3v3c-4 0-6-2-6-6V7Zm9 0h4v4h-3c0 2 1 3 3 3v3c-4 0-6-2-6-6V7Z"/>
  </svg>
)}
