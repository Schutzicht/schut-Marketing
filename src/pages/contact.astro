---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";

const channels = [
  {
    label: "WhatsApp",
    sub: "Snelst voor korte vragen",
    value: site.phone,
    icon: "phone",
    href: site.whatsappHref,
    bg: "bg-mint",
  },
  {
    label: "Bellen",
    sub: "Werkdagen 09:00 - 17:30",
    value: site.phone,
    icon: "phone",
    href: site.phoneHref,
    bg: "bg-cyan",
  },
  {
    label: "Mailen",
    sub: "Reactie meestal binnen één werkdag",
    value: site.email,
    icon: "mail",
    href: `mailto:${site.email}`,
    bg: "bg-peach",
  },
] as const;
---

<Base title="Contact | Schut Marketing" description="Direct in contact met Jorik Schut. App, bel of mail voor een vrijblijvende kennismaking.">
  <section class="pt-28 md:pt-40 pb-20 md:pb-28 relative overflow-hidden">
    <span aria-hidden="true" class="absolute top-32 -right-32 w-[460px] h-[460px] rounded-full bg-mint/20 blur-[120px] pointer-events-none"></span>
    <span aria-hidden="true" class="absolute bottom-0 -left-32 w-[360px] h-[360px] rounded-full bg-cyan/15 blur-[120px] pointer-events-none"></span>

    <div class="container-sm relative">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-6" data-reveal>
          <p class="eyebrow">Contact</p>
          <h1 class="mt-4 text-[40px] sm:text-[56px] md:text-[72px] lg:text-[84px] font-extrabold leading-[1] sm:leading-[0.94] tracking-[-0.03em] sm:tracking-[-0.04em]">
            Even <span class="italic-serif text-mint-deep">kennismaken</span>.
          </h1>
          <p class="mt-7 max-w-xl text-[16.5px] md:text-[17px] leading-[1.7] text-ink-soft">
            Een eerste gesprek is altijd vrijblijvend. We koffieën, kijken samen wat je wilt bereiken, en bekijken of het past. Geen druk, geen verkooppraatje.
          </p>
          <p class="mt-4 max-w-xl text-[15px] md:text-[15.5px] leading-[1.7] text-ink-soft">
            Het makkelijkst is een appje. Bellen kan ook, en als je liever schriftelijk start: mail mag altijd.
          </p>

          <div class="hairline my-10"></div>

          <div class="flex items-center gap-4">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-canvas-2 text-ink border border-line">
              <Icon name="pin" size={18} />
            </span>
            <div>
              <p class="eyebrow !text-ink-soft">Locatie</p>
              <p class="mt-1 text-[18px] sm:text-[20px] font-bold tracking-tight">{site.city}</p>
            </div>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-[13px] text-ink-soft">
            <a href={site.socials.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-ink"><Icon name="linkedin" size={16} /> LinkedIn Jorik Schut</a>
            <a href={site.socials.agensea} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-ink"><Icon name="arrow-up-right" size={16} /> agensea.nl</a>
          </div>
        </div>

        <div class="lg:col-span-6 space-y-4" data-reveal>
          {channels.map((c, i) => (
            <a
              href={c.href}
              target={c.href.startsWith("http") ? "_blank" : undefined}
              rel={c.href.startsWith("http") ? "noopener" : undefined}
              class="card flex items-center gap-5 p-5 sm:p-6 group"
              style={`transition-delay: ${i * 50}ms`}
              data-reveal
            >
              <span class={`inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl ${c.bg} text-ink ring-8 ring-canvas-2 group-hover:ring-mint-fog transition-all`}>
                <Icon name={c.icon} size={22} />
              </span>
              <div class="flex-1 min-w-0">
                <p class="eyebrow !text-ink-soft">{c.label}</p>
                <p class="mt-0.5 text-[20px] sm:text-[22px] font-bold tracking-tight break-all group-hover:text-mint-deep transition-colors">{c.value}</p>
                <p class="mt-1 text-[13px] text-ink-soft">{c.sub}</p>
              </div>
              <Icon name="arrow-up-right" size={20} class="shrink-0 text-ink-soft group-hover:text-mint-deep transition-colors" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
